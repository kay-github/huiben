.page-shell {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}

.page-glow {
  position: fixed;
  pointer-events: none;
  border-radius: 999rpx;
  opacity: 0.7;
}

.page-glow--top {
  top: -180rpx;
  left: 50%;
  width: 820rpx;
  height: 520rpx;
  margin-left: -410rpx;
  background: radial-gradient(circle at center, rgba(0, 242, 255, 0.18), rgba(0, 242, 255, 0));
}

.page-glow--side {
  top: 520rpx;
  right: -220rpx;
  width: 480rpx;
  height: 480rpx;
  background: radial-gradient(circle at center, rgba(97, 122, 255, 0.12), rgba(97, 122, 255, 0));
}

.topbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  background: rgba(4, 5, 6, 0.9);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.topbar__content {
  display: flex;
  align-items: center;
  justify-content: center;
}

.brand-mark {
  position: relative;
  width: 30rpx;
  height: 30rpx;
  margin-right: 16rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #00f2ff 0%, #0da4ff 100%);
  box-shadow: 0 0 32rpx rgba(0, 242, 255, 0.28);
}

.brand-mark__core {
  position: absolute;
  top: 7rpx;
  left: 7rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 6rpx;
  border: 3rpx solid rgba(5, 8, 10, 0.92);
}

.brand-title {
  font-size: 42rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  color: #f4f7fb;
}

.page-main {
  position: relative;
  width: 100%;
  max-width: 750rpx;
  margin: 0 auto;
  padding-left: 48rpx;
  padding-right: 48rpx;
}

.subtitle {
  display: block;
  margin-top: 52rpx;
  margin-bottom: 72rpx;
  text-align: center;
  font-size: 30rpx;
  line-height: 1.8;
  color: rgba(244, 247, 251, 0.7);
}

.input-panel {
  padding: 40rpx;
  border-radius: 36rpx;
  background: rgba(15, 18, 20, 0.88);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05),
    0 24rpx 60rpx rgba(0, 0, 0, 0.24);
}

.input-panel--focus {
  border-color: rgba(0, 242, 255, 0.46);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.06),
    0 0 0 2rpx rgba(0, 242, 255, 0.08),
    0 28rpx 66rpx rgba(0, 0, 0, 0.28);
}

.input-panel__header {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  min-height: 40rpx;
}

.input-label {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(244, 247, 251, 0.68);
}

.clear-action {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1.4;
  color: rgba(244, 247, 251, 0.6);
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.input-field {
  margin-top: 34rpx;
  min-height: 186rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 28rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.02);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.02);
}

.input-control {
  flex: 1;
  min-width: 0;
  padding: 0;
  text-align: center;
  font-size: 92rpx;
  font-weight: 600;
  line-height: 1;
  color: #f4f7fb;
}

.input-placeholder {
  color: rgba(244, 247, 251, 0.14);
}

.input-unit {
  margin-left: 18rpx;
  margin-top: 12rpx;
  font-size: 56rpx;
  font-weight: 600;
  color: rgba(244, 247, 251, 0.26);
}

.inline-hint {
  display: block;
  margin-top: 22rpx;
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 185, 92, 0.92);
}

.result-panel {
  margin-top: 96rpx;
  text-align: center;
}

.result-label {
  display: block;
  margin-bottom: 28rpx;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 8rpx;
  color: #00d7e7;
}

.result-panel__content {
  min-height: 250rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-value {
  display: inline-flex;
  align-items: flex-end;
  justify-content: center;
  max-width: 100%;
}

.result-value--placeholder {
  opacity: 0.5;
}

.result-number {
  max-width: 100%;
  font-size: 160rpx;
  line-height: 0.96;
  font-weight: 700;
  letter-spacing: -5rpx;
  color: #00f2ff;
  text-shadow:
    0 0 18rpx rgba(0, 242, 255, 0.22),
    0 12rpx 32rpx rgba(0, 242, 255, 0.1);
}

.result-number--compact {
  font-size: 134rpx;
}

.result-number--small {
  font-size: 112rpx;
}

.result-number--placeholder {
  color: rgba(244, 247, 251, 0.34);
  text-shadow: none;
}

.result-unit {
  margin-left: 10rpx;
  margin-bottom: 18rpx;
  font-size: 66rpx;
  font-weight: 600;
  color: rgba(0, 242, 255, 0.78);
}

.result-unit--placeholder {
  color: rgba(244, 247, 251, 0.28);
}

.abnormal-title {
  display: block;
  font-size: 72rpx;
  line-height: 1.12;
  font-weight: 700;
  color: rgba(244, 247, 251, 0.92);
}

.abnormal-desc {
  display: block;
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: rgba(244, 247, 251, 0.5);
}

.quick-panel {
  margin-top: 92rpx;
}

.quick-label {
  display: block;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  color: rgba(244, 247, 251, 0.5);
}

.quick-grid {
  display: flex;
  flex-wrap: wrap;
  overflow: hidden;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
  border-left: 1rpx solid rgba(255, 255, 255, 0.05);
  background: rgba(7, 9, 11, 0.6);
}

.quick-item {
  width: 33.3333%;
  padding: 26rpx 24rpx 24rpx;
  border-right: 1rpx solid rgba(255, 255, 255, 0.05);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.quick-item--active {
  background: rgba(0, 242, 255, 0.08);
  border-right-color: rgba(0, 242, 255, 0.18);
  border-bottom-color: rgba(0, 242, 255, 0.18);
}

.quick-loss {
  display: block;
  font-size: 22rpx;
  line-height: 1.6;
  color: rgba(244, 247, 251, 0.44);
}

.quick-result {
  display: block;
  margin-top: 8rpx;
  font-size: 38rpx;
  line-height: 1.3;
  font-weight: 500;
  color: rgba(244, 247, 251, 0.84);
}

.footer-note {
  display: block;
  margin-top: 88rpx;
  text-align: center;
  font-size: 24rpx;
  line-height: 1.8;
  color: rgba(244, 247, 251, 0.4);
}

@media (max-width: 360px) {
  .page-main {
    padding-left: 32rpx;
    padding-right: 32rpx;
  }

  .input-panel {
    padding: 34rpx;
  }

  .input-control {
    font-size: 82rpx;
  }

  .result-number {
    font-size: 136rpx;
  }

  .result-number--compact {
    font-size: 116rpx;
  }

  .result-number--small {
    font-size: 98rpx;
  }

  .quick-item {
    padding-left: 18rpx;
    padding-right: 18rpx;
  }

  .quick-result {
    font-size: 34rpx;
  }
}
